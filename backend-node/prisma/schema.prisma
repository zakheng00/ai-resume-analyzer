// Prisma Schema
// Database schema for AI Resume Analyzer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id        String     @id @default(cuid())
  fileName  String
  fileSize  Int
  mimeType  String
  extractedText String  @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  analyses  Analysis[]
  
  @@index([createdAt])
}

model Analysis {
  id        String     @id @default(cuid())
  resumeId  String
  resume    Resume     @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  analysisType String   // "general", "technical", "ats", etc.
  results   Json       // Store Dify AI response as JSON
  score     Int?       // Overall score if applicable
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([resumeId])
  @@index([createdAt])
}
